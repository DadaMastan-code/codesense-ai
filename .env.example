# ── LLM API Keys ──────────────────────────────────────────────────────────────
# Get a free Groq key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: OpenAI fallback
OPENAI_API_KEY=your_openai_api_key_here

# ── Model Settings ────────────────────────────────────────────────────────────
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_MODEL=gpt-4o
MAX_TOKENS=4096
TEMPERATURE=0.1
REQUEST_TIMEOUT=30

# ── App Settings ──────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=10
LOG_LEVEL=INFO
ENVIRONMENT=development

# ── GitHub Webhook (for automatic PR reviews) ────────────────────────────────
# Set this secret in your GitHub repo: Settings → Webhooks → Secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
# GitHub token with repo + write:discussion scope (for posting PR comments)
GITHUB_TOKEN=ghp_your_github_token_here

# ── LangSmith Tracing (optional — free at smith.langchain.com) ───────────────
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=codesense-ai
LANGSMITH_TRACING_ENABLED=false

# ── Evolution Tracker ─────────────────────────────────────────────────────────
EVOLUTION_DB_PATH=data/evolution.db
